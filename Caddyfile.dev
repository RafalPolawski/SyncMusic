# Caddyfile.dev — used by docker-compose.dev.yml (Vite dev server on port 5173)
{
	auto_https off
	local_certs
	on_demand_tls {
		ask http://syncmusic-backend:8080/api/ok
	}
}

http://:80 {
	@api   { path /api/* }
	@music { path /music/* }

	handle @api   { reverse_proxy syncmusic-backend:8080 }
	handle @music { reverse_proxy syncmusic-backend:8080 }
	handle        { reverse_proxy syncmusic-frontend:5173 }
}

:443 {
	tls internal { on_demand }

	@api   { path /api/* }
	@music { path /music/* }

	handle @api   { reverse_proxy syncmusic-backend:8080 }
	handle @music { reverse_proxy syncmusic-backend:8080 }
	handle        { reverse_proxy syncmusic-frontend:5173 }
}
