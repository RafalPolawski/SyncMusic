{
	# Global options
	# Disable forced redirection to HTTPS on port 80 (standard HTTP).
	# This fixes Service Worker registration on http://localhost.
	auto_https off

	# Enable on-demand TLS for Tailscale/custom domains
	on_demand_tls {
		ask http://syncmusic-backend:8080/api/ok
	}

	# Required for internal CA usage
	local_certs
}

# (Snippet) Reusable proxy logic for all protocols
(syncmusic_proxy) {
	# API Endpoints
	@api {
		path /api/*
	}
	handle @api {
		reverse_proxy syncmusic-backend:8080
	}

	# Music Files (Audio + Cover Art)
	@music {
		path /music/*
	}
	handle @music {
		reverse_proxy syncmusic-backend:8080
	}

	# Keycloak Authentication
	@auth {
		path /auth/* /realms/* /resources/*
	}
	handle @auth {
		reverse_proxy syncmusic-keycloak:8080
	}

	# Frontend - Static files or Dev Server
	handle {
		# If FRONTEND_DEV is set, proxy to Vite dev server (hot reload)
		@dev_server {
			expression {env.FRONTEND_DEV} != ""
		}
		handle @dev_server {
			reverse_proxy syncmusic-frontend:5173
		}

		# Otherwise, serve static build from disk (Production mode)
		handle {
			root * /usr/share/caddy
			file_server
			try_files {path} /index.html
		}
	}
}

# Catch-all HTTP (Port 80 inside container)
# Accessible via http://localhost or http://<tailscale-ip>
:80 {
	import syncmusic_proxy
}

# Catch-all HTTPS (Port 443 inside container)
# Self-signed certificates granted for any domain that hits this.
:443 {
	# Use internal CA for Tailscale/LAN, with on-demand cert generation
	tls internal {
		on_demand
	}
	import syncmusic_proxy
}

# WebTransport (Handled directly by Backend)
:4433 {
}
